import tkinter as tk
from tkinter import messagebox
import matplotlib.pyplot as plt
from collections import defaultdict

class StudentSystem:
    def __init__(self, root):
        self.root = root
        self.root.title("Student Performance Management System")
        self.root.geometry("400x500")

        # Data Store
        self.students = []

        # UI Elements
        tk.Label(root, text="Student Name:").pack(pady=5)
        self.ent_name = tk.Entry(root)
        self.ent_name.pack()

        tk.Label(root, text="Roll Number:").pack(pady=5)
        self.ent_roll = tk.Entry(root)
        self.ent_roll.pack()

        tk.Label(root, text="Mentor Name:").pack(pady=5)
        self.ent_mentor = tk.Entry(root)
        self.ent_mentor.pack()

        tk.Label(root, text="Marks:").pack(pady=5)
        self.ent_marks = tk.Entry(root)
        self.ent_marks.pack()

        # Buttons
        tk.Button(root, text="Add Student", command=self.add_student, bg="#4CAF50", fg="white").pack(pady=10)
        tk.Button(root, text="Display Topper", command=self.display_topper, bg="#2196F3", fg="white").pack(pady=5)
        tk.Button(root, text="Show Mentor Performance Graph", command=self.plot_graph, bg="#FF9800", fg="white").pack(pady=5)

    def add_student(self):
        name = self.ent_name.get().strip()
        roll = self.ent_roll.get().strip()
        mentor = self.ent_mentor.get().strip()
        marks_raw = self.ent_marks.get().strip()

        # Validation
        if not all([name, roll, mentor, marks_raw]):
            messagebox.showerror("Error", "All fields are required!")
            return
        
        try:
            marks = float(marks_raw)
            if not (0 <= marks <= 100):
                raise ValueError
        except ValueError:
            messagebox.showerror("Error", "Please enter valid marks (0-100)")
            return

        # Store record
        self.students.append({
            "name": name,
            "roll": roll,
            "mentor": mentor,
            "marks": marks
        })

        messagebox.showinfo("Success", f"Record for {name} added!")
        self.clear_entries()

    def clear_entries(self):
        self.ent_name.delete(0, tk.END)
        self.ent_roll.delete(0, tk.END)
        self.ent_mentor.delete(0, tk.END)
        self.ent_marks.delete(0, tk.END)

    def display_topper(self):
        if not self.students:
            messagebox.showwarning("Empty", "No student records found.")
            return

        topper = max(self.students, key=lambda x: x['marks'])
        info = f"Topper: {topper['name']}\nRoll: {topper['roll']}\nMarks: {topper['marks']}"
        messagebox.showinfo("Topper Details", info)

    def plot_graph(self):
        if not self.students:
            messagebox.showwarning("Empty", "Add data before plotting.")
            return

        # Group marks by mentor
        mentor_data = defaultdict(list)
        for s in self.students:
            mentor_data[s['mentor']].append(s['marks'])

        # Calculate averages
        mentors = list(mentor_data.keys())
        averages = [sum(marks)/len(marks) for marks in mentor_data.values()]

        # Plotting
        plt.figure(figsize=(8, 5))
        plt.bar(mentors, averages, color='skyblue', edgecolor='navy')
        plt.xlabel('Mentor Name')
        plt.ylabel('Average Student Marks')
        plt.title('Performance by Mentor Group')
        plt.ylim(0, 105) # Marks are usually out of 100
        plt.show()

if __name__ == "__main__":
    root = tk.Tk()
    app = StudentSystem(root)
    root.mainloop()